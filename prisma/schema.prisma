generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  socialAccounts SocialAccount[]
  issueReports   IssueReport[]
  publishTasks   PublishTask[]
  sessions       UserSession[]
  passwordResets PasswordResetToken[]
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String
  tokenHash    String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  lastSeenAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model SocialAccount {
  id                    String   @id @default(cuid())
  userId                String
  platform              String
  platformAccountId     String
  displayName           String
  status                String   @default("authorized")
  scopes                String[] @default([])
  accessTokenEncrypted  String
  refreshTokenEncrypted String?
  tokenExpiresAt        DateTime?
  favorite              Boolean  @default(false)
  groupName             String   @default("")
  sortOrder             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  metricSnapshots MetricSnapshot[]
  publishTasks PublishTask[]

  @@unique([userId, platform, platformAccountId])
  @@index([userId, platform])
}

model PublishTask {
  id              String        @id @default(cuid())
  userId          String
  socialAccountId String
  platform        String
  title           String
  description     String        @default("")
  contentType     String        @default("video")
  publishMode     String        @default("scheduled")
  visibility      String        @default("private")
  scheduledAt     DateTime?
  status          String        @default("queued")
  mediaFileName   String?
  coverFileName   String?
  youtubeVideoId  String?
  youtubeUrl      String?
  errorMessage    String?
  settings        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@index([socialAccountId, createdAt])
  @@index([platform, status])
}

model MetricSnapshot {
  id              String   @id @default(cuid())
  socialAccountId String
  platform        String
  date            DateTime
  subscriberCount Int?
  viewCount       BigInt?
  videoCount      Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)

  @@unique([socialAccountId, date])
  @@index([socialAccountId, date])
  @@index([platform, date])
}

model IssueReport {
  id        String   @id @default(cuid())
  userId    String?
  email     String?
  category  String   @default("general")
  page      String   @default("")
  message   String
  status    String   @default("open")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([userId, createdAt])
}
